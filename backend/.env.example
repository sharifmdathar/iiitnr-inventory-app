DATABASE_URL=postgresql://postgres:PASSWORD@db.example.com:6543/postgres
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/iiitnr_inventory_test

PORT=4000

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_EXTRA_IDS=

ALLOWED_EMAIL_DOMAIN=@iiitnr.edu.in
ALLOW_UNVERIFIED_EMAIL=false

# CORS — comma-separated list of origins
ALLOWED_ORIGINS=

# Seed admin
ADMIN_EMAIL=admin@iiitnr.edu.in
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME=Inventory Admin
