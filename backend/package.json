{
  "name": "@iiitnr/backend",
  "version": "1.14.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run migrate && bun --watch src/server.ts",
    "build": "tsc",
    "start": "bun run migrate && bun run src/server.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "migrate": "bun run src/index.ts",
    "seed": "bun run scripts/seed.ts",
    "create:user": "bun run scripts/create-user.ts",
    "migrate:backup": "bun run scripts/migrate-with-backup.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "10.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "ajv": "^8.20.0",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "5.9.0",
    "google-auth-library": "^10.9.0",
    "pg": "8.22.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/pg": "8.18.0",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.7.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.9.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "resolutions": {
    "@types/pg": "8.18.0"
  }
}
