{
  "name": "@iiitnr/backend",
  "version": "1.13.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "bun run src/server.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "create:user": "tsx scripts/create-user.ts",
    "migrate:backup": "bun run scripts/migrate-with-backup.ts",
    "test": "bun test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "bcryptjs": "3.0.3",
    "dotenv": "17.3.1",
    "fastify": "5.8.1",
    "google-auth-library": "^10.6.1",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.10",
    "@types/pg": "8.18.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.4.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "prisma": "7.4.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
