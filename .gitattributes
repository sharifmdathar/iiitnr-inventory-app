# Set the default behavior, in case people don't have core.autocrlf set.
* text=auto

# Force LF for specific files that we know should be Unix-style
*.sh text eol=lf
*.bash text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.json text eol=lf

# Force CRLF for Windows-specific scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
